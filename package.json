{
  "name": "tic-tac-toe-node-app",
  "version": "1.0.0",
  "description": "Node service for Tic-Tac-Toe",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build:node": "tsc",
    "build:nakama": "rollup -c && sed -i 's/^export //g' dist/modules/index.js && sed -i '/^export {/d' dist/modules/index.js",
    "build": "npm run build:node && npm run build:nakama",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "format": "^0.2.2",
    "prettier": "^3.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "nakama-runtime": "github:heroiclabs/nakama-common",
    "rollup": "^4.60.1",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
